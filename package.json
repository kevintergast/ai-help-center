{
  "name": "hallofhelp",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:check": "node scripts/check-i18n.mjs",
    "prepare": "husky",
    "db:migrate:local": "wrangler d1 migrations apply hallofhelp-staging --local",
    "db:migrate:staging": "wrangler d1 migrations apply hallofhelp-staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply hallofhelp-prod --env production --remote",
    "seed:content:sql": "node scripts/seed-operator-content.mjs > /tmp/hoh-op-seed.sql",
    "seed:content:local": "pnpm seed:content:sql && wrangler d1 execute hallofhelp-staging --local --file=/tmp/hoh-op-seed.sql",
    "seed:content:staging": "pnpm seed:content:sql && wrangler d1 execute hallofhelp-staging --remote --file=/tmp/hoh-op-seed.sql",
    "seed:content:prod": "pnpm seed:content:sql && wrangler d1 execute hallofhelp-prod --env production --remote --file=/tmp/hoh-op-seed.sql"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "better-auth": "^1.2.0",
    "hono": "^4.6.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@eslint/eslintrc": "^3.3.6",
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.11.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "unrs-resolver",
      "better-sqlite3"
    ]
  }
}
